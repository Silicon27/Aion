main () :: i32 {
    for (let i = 0; i < 10; i++) {
        // do something
    }

    // alternative syntax uses range filling
    // for [type] [identifier] [start]..[end] { ... }
    for i 0..10 { // i is default typed as size
        // functionally same as `for (let i: size; i < 11; i++) { ... }`
    }
}